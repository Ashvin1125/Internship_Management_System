@{
    ViewData["Title"] = "Guide Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="ims-card h-100 border-start border-info border-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small fw-bold text-uppercase mb-1">Assigned Students</p>
                    <h2 class="mb-0 fw-bold px-0">@ViewBag.AssignedStudents</h2>
                </div>
                <div class="bg-info bg-opacity-10 p-3 rounded-circle">
                    <i class="bi bi-people-fill fs-4 text-info"></i>
                </div>
            </div>
            <div class="mt-3">
                <a class="small text-info fw-bold text-decoration-none stretched-link" asp-action="Students">My Students <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ims-card h-100 border-start border-warning border-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small fw-bold text-uppercase mb-1">Pending Diaries</p>
                    <h2 class="mb-0 fw-bold text-warning px-0">@ViewBag.PendingDiaries</h2>
                </div>
                <div class="bg-warning bg-opacity-10 p-3 rounded-circle">
                    <i class="bi bi-journal-check fs-4 text-warning"></i>
                </div>
            </div>
            <div class="mt-3">
                <a class="small text-warning fw-bold text-decoration-none stretched-link" asp-action="Diaries">Review Now <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ims-card h-100 border-start border-success border-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small fw-bold text-uppercase mb-1">Weekly Reports</p>
                    <h2 class="mb-0 fw-bold text-success px-0">@ViewBag.PendingWeeklyReports</h2>
                </div>
                <div class="bg-success bg-opacity-10 p-3 rounded-circle">
                    <i class="bi bi-file-earmark-bar-graph fs-4 text-success"></i>
                </div>
            </div>
            <div class="mt-3">
                <a class="small text-success fw-bold text-decoration-none stretched-link" asp-action="WeeklyReports">Review Reports <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ims-card h-100 border-start border-primary border-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small fw-bold text-uppercase mb-1">Tasks Assigned</p>
                    <h2 class="mb-0 fw-bold text-primary px-0">@ViewBag.TasksAssigned</h2>
                </div>
                <div class="bg-primary bg-opacity-10 p-3 rounded-circle">
                    <i class="bi bi-list-check fs-4 text-primary"></i>
                </div>
            </div>
            <div class="mt-3">
                <a class="small text-primary fw-bold text-decoration-none stretched-link" asp-action="Tasks">View All Tasks <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="ims-card h-100">
            <div class="border-bottom border-light pb-3 mb-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-lightning-fill text-warning me-2"></i>Guide Essentials</h5>
            </div>
            <div class="list-group list-group-flush bg-transparent">
                <a asp-action="Diaries" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 border-0 rounded bg-transparent ims-hover-accent">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-warning bg-opacity-10 p-2 rounded-circle"><i class="bi bi-journal-check text-warning"></i></div>
                        <span class="fw-bold">Pending Review Diaries</span>
                    </div>
                    <i class="bi bi-chevron-right small text-muted"></i>
                </a>
                <a asp-action="AssignTask" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 border-0 rounded bg-transparent ims-hover-accent">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-primary bg-opacity-10 p-2 rounded-circle"><i class="bi bi-plus-circle text-primary"></i></div>
                        <span class="fw-bold">Assign New Internship Task</span>
                    </div>
                    <i class="bi bi-chevron-right small text-muted"></i>
                </a>
                <a asp-action="WeeklyReports" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 border-0 rounded bg-transparent ims-hover-accent">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-success bg-opacity-10 p-2 rounded-circle"><i class="bi bi-file-earmark-bar-graph text-success"></i></div>
                        <span class="fw-bold">Review Weekly Reports</span>
                    </div>
                    <i class="bi bi-chevron-right small text-muted"></i>
                </a>
                <a asp-action="Students" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 border-0 rounded bg-transparent ims-hover-accent">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-info bg-opacity-10 p-2 rounded-circle"><i class="bi bi-people text-info"></i></div>
                        <span class="fw-bold">Browse Assigned Student Profiles</span>
                    </div>
                    <i class="bi bi-chevron-right small text-muted"></i>
                </a>
            </div>
        </div>
    </div>
</div>
