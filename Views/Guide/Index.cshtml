@{
    ViewData["Title"] = "Guide Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card bg-info text-white">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div><h6>Assigned Students</h6><h2 class="mb-0">@ViewBag.AssignedStudents</h2></div>
                <i class="bi bi-people-fill fs-1 text-white-50"></i>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <a class="small text-white stretched-link" asp-action="Students">View All</a>
                <i class="bi bi-arrow-right text-white"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-dark">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div><h6>Pending Diaries</h6><h2 class="mb-0">@ViewBag.PendingDiaries</h2></div>
                <i class="bi bi-journal-check fs-1 opacity-50"></i>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <a class="small text-dark stretched-link" asp-action="Diaries">Review Now</a>
                <i class="bi bi-arrow-right"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div><h6>Tasks Assigned</h6><h2 class="mb-0">@ViewBag.TasksAssigned</h2></div>
                <i class="bi bi-list-check fs-1 text-white-50"></i>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <a class="small text-white stretched-link" asp-action="Tasks">View All Tasks</a>
                <i class="bi bi-arrow-right text-white"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-lightning-fill text-warning me-2"></i>Quick Actions</div>
            <div class="card-body d-flex flex-column gap-2">
                <a asp-action="Diaries" class="btn btn-outline-warning"><i class="bi bi-journal-check me-2"></i>Review Student Diaries</a>
                <a asp-action="AssignTask" class="btn btn-outline-primary"><i class="bi bi-plus-circle me-2"></i>Assign New Task</a>
                <a asp-action="Students" class="btn btn-outline-secondary"><i class="bi bi-people me-2"></i>View My Students</a>
            </div>
        </div>
    </div>
</div>
