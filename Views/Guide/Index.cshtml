@using InternshipManagementSystem.Services
@model GuideStats
@{
    ViewData["Title"] = "Guide Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="ims-card h-100 border-start border-info border-4 shadow-sm">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small fw-bold text-uppercase mb-1">Assigned Students</p>
                    <h2 class="mb-0 fw-bold px-0">@Model.AssignedStudents</h2>
                </div>
                <div class="bg-info bg-opacity-10 p-3 rounded-circle">
                    <i class="bi bi-people-fill fs-4 text-info"></i>
                </div>
            </div>
            <div class="mt-3">
                <a class="small text-info fw-bold text-decoration-none stretched-link" asp-action="Students">My Students <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ims-card h-100 border-start border-warning border-4 shadow-sm">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small fw-bold text-uppercase mb-1">Pending Diaries</p>
                    <h2 class="mb-0 fw-bold text-warning px-0">@Model.PendingDiaries</h2>
                </div>
                <div class="bg-warning bg-opacity-10 p-3 rounded-circle">
                    <i class="bi bi-journal-check fs-4 text-warning"></i>
                </div>
            </div>
            <div class="mt-3">
                <a class="small text-warning fw-bold text-decoration-none stretched-link" asp-action="Diaries">Review Now <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ims-card h-100 border-start border-success border-4 shadow-sm">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small fw-bold text-uppercase mb-1">Tasks Assigned</p>
                    <h2 class="mb-0 fw-bold text-success px-0">@Model.TasksAssigned</h2>
                </div>
                <div class="bg-success bg-opacity-10 p-3 rounded-circle">
                    <i class="bi bi-list-check fs-4 text-success"></i>
                </div>
            </div>
            <div class="mt-3">
                <a class="small text-success fw-bold text-decoration-none stretched-link" asp-action="Tasks">View Tasks <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ims-card h-100 border-start border-primary border-4 shadow-sm">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small fw-bold text-uppercase mb-1">Tasks Completed</p>
                    <h2 class="mb-0 fw-bold text-primary px-0">@Model.TasksCompleted</h2>
                </div>
                <div class="bg-primary bg-opacity-10 p-3 rounded-circle">
                    <i class="bi bi-check-circle-fill fs-4 text-primary"></i>
                </div>
            </div>
            <div class="mt-3">
                <a class="small text-primary fw-bold text-decoration-none stretched-link" asp-action="Tasks">Check Status <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-7">
        <div class="ims-card h-100 shadow-sm">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="mb-0 fw-bold">Recent Student Diaries</h5>
                <a asp-action="Diaries" class="small text-primary text-decoration-none">View All</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="small text-uppercase text-muted">
                            <th>Student</th>
                            <th>Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentDiaries.Any())
                        {
                            foreach (var d in Model.RecentDiaries)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold small">@d.Student?.User?.Name</div>
                                    </td>
                                    <td><small class="text-muted">@d.WorkDate.ToShortDateString()</small></td>
                                    <td>
                                        @{
                                            var badgeClass = d.Status == "Approved" ? "bg-success" : (d.Status == "Pending" ? "bg-warning" : "bg-danger");
                                        }
                                        <span class="badge @badgeClass" style="font-size: 0.65rem;">@d.Status</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="3" class="text-center p-4 text-muted small">No recent diaries</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="ims-card h-100 shadow-sm">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="mb-0 fw-bold">Task Completion Status</h5>
                <i class="bi bi-pie-chart text-muted"></i>
            </div>
            <div style="height: 250px;">
                <canvas id="taskChart"></canvas>
            </div>
            <div class="text-center mt-3">
                <div class="badge bg-primary bg-opacity-10 text-primary p-2">
                    Overall Progress: @(Model.TasksAssigned > 0 ? (Model.TasksCompleted * 100 / Model.TasksAssigned) : 0)%
                </div>
            </div>
        </div>
    </div>
</div>

<div class="ims-card shadow-sm">
    <div class="border-bottom border-light pb-3 mb-3">
        <h5 class="mb-0 fw-bold"><i class="bi bi-lightning-fill text-warning me-2"></i>Quick Actions</h5>
    </div>
    <div class="row g-3">
        <div class="col-6 col-md-3">
            <a asp-action="Diaries" class="ims-btn ims-btn-primary w-100 text-center py-3 d-flex flex-column gap-2 ims-btn-glow">
                <i class="bi bi-journal-check fs-4"></i>
                <span class="small">Review Diaries</span>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="AssignTask" class="ims-btn ims-btn-secondary w-100 text-center py-3 d-flex flex-column gap-2" style="background: #8b5cf6; border-color: #8b5cf6; color: white;">
                <i class="bi bi-plus-circle fs-4"></i>
                <span class="small">Assign Task</span>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="WeeklyReports" class="ims-btn ims-btn-outline w-100 text-center py-3 d-flex flex-column gap-2 border-success text-success">
                <i class="bi bi-file-earmark-bar-graph fs-4"></i>
                <span class="small">Weekly Reports</span>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="Chat" asp-action="Index" class="ims-btn ims-btn-outline w-100 text-center py-3 d-flex flex-column gap-2 border-info text-info">
                <i class="bi bi-chat-dots fs-4"></i>
                <span class="small">Messages</span>
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const taskCtx = document.getElementById('taskChart');
        new Chart(taskCtx, {
            type: 'doughnut',
            data: {
                labels: ['Completed', 'Pending'],
                datasets: [{
                    data: [@Model.TasksCompleted, @(Model.TasksAssigned - Model.TasksCompleted)],
                    backgroundColor: ['#10b981', '#3b82f6'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom', labels: { usePointStyle: true, padding: 15 } }
                },
                cutout: '75%'
            }
        });
    </script>
}
