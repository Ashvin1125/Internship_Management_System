@{
    ViewData["Title"] = "Guide Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card card-stats h-100 border-start border-info border-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small fw-bold text-uppercase mb-1">Assigned Students</p>
                        <h2 class="mb-0 fw-bold">@ViewBag.AssignedStudents</h2>
                    </div>
                    <div class="bg-info bg-opacity-10 p-2 rounded">
                        <i class="bi bi-people-fill fs-4 text-info"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <a class="small text-info fw-bold text-decoration-none stretched-link" asp-action="Students">My Students <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card card-stats h-100 border-start border-warning border-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small fw-bold text-uppercase mb-1">Pending Diaries</p>
                        <h2 class="mb-0 fw-bold text-warning">@ViewBag.PendingDiaries</h2>
                    </div>
                    <div class="bg-warning bg-opacity-10 p-2 rounded">
                        <i class="bi bi-journal-check fs-4 text-warning"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <a class="small text-warning fw-bold text-decoration-none stretched-link" asp-action="Diaries">Review Now <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card card-stats h-100 border-start border-primary border-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small fw-bold text-uppercase mb-1">Tasks Assigned</p>
                        <h2 class="mb-0 fw-bold text-primary">@ViewBag.TasksAssigned</h2>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-2 rounded">
                        <i class="bi bi-list-check fs-4 text-primary"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <a class="small text-primary fw-bold text-decoration-none stretched-link" asp-action="Tasks">View All Tasks <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-lightning-fill text-warning me-2"></i>Guide Essentials</h5>
            </div>
            <div class="card-body">
                <div class="list-group list-group-flush">
                    <a asp-action="Diaries" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3">
                        <span><i class="bi bi-journal-check me-2 text-warning"></i> Pending Review Diaries</span>
                        <i class="bi bi-chevron-right small text-muted"></i>
                    </a>
                    <a asp-action="AssignTask" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3">
                        <span><i class="bi bi-plus-circle me-2 text-primary"></i> Assign New Internship Task</span>
                        <i class="bi bi-chevron-right small text-muted"></i>
                    </a>
                    <a asp-action="Students" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3">
                        <span><i class="bi bi-people me-2 text-info"></i> Browse Assigned Student Profiles</span>
                        <i class="bi bi-chevron-right small text-muted"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
