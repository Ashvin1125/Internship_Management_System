@model IEnumerable<InternshipManagementSystem.Models.DailyDiary>

@{
    ViewData["Title"] = "Student Diaries";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Student Diaries for Review</h2>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Student</th>
                        <th>Work Description</th>
                        <th>Status</th>
                        <th style="min-width:260px">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model ?? Enumerable.Empty<InternshipManagementSystem.Models.DailyDiary>())
                    {
                        <tr>
                            <td>@item.WorkDate.ToShortDateString()</td>
                            <td>@item.Student?.User?.Name</td>
                            <td>@(item.WorkDescription?.Length > 50 ? item.WorkDescription.Substring(0, 50) + "..." : item.WorkDescription)</td>
                            <td>
                                @if (item.Status == "Pending") { <span class="badge bg-warning text-dark">Pending</span> }
                                else if (item.Status == "Approved") { <span class="badge bg-success">Approved</span> }
                                else { <span class="badge bg-danger">Rejected</span> }
                            </td>
                            <td>
                                @if (item.Status == "Pending")
                                {
                                    <form asp-action="ApproveDiary" method="post" class="d-flex gap-1 align-items-center">
                                        <input type="hidden" name="diaryId" value="@item.DiaryId" />
                                        <input type="text" name="comment" class="form-control form-control-sm" placeholder="Comment..." />
                                        <button type="submit" name="action" value="Approve" class="btn btn-sm btn-success">✓</button>
                                        <button type="submit" name="action" value="Reject" class="btn btn-sm btn-danger">✗</button>
                                    </form>
                                }
                                else
                                {
                                    <small class="text-muted">@item.GuideComment</small>
                                }
                            </td>
                        </tr>
                    }
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">No diary entries submitted yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
