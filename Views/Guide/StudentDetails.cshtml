@model InternshipManagementSystem.Models.Student

@{
    ViewData["Title"] = "Student Profile";
    var internship = ViewBag.Internship as InternshipManagementSystem.Models.InternshipDetails;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Student Details: @Model.User.Name</h2>
    <a asp-action="Students" class="btn btn-secondary shadow-sm"><i class="bi bi-arrow-left me-1"></i> My Students</a>
</div>

<div class="row">
    <!-- Left: Profile & Statistics -->
    <div class="col-md-4">
        <div class="card shadow-sm mb-4 border-0 border-start border-primary border-4">
            <div class="card-header bg-white border-bottom-0">
                <h5 class="mb-0 text-primary fw-bold"><i class="bi bi-person-circle me-2"></i>Academic Info</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5 text-muted small text-uppercase">Enrollment</dt>
                    <dd class="col-sm-7 fw-bold">@Model.EnrollmentNumber</dd>
                    
                    <dt class="col-sm-5 text-muted small text-uppercase">Department</dt>
                    <dd class="col-sm-7">@Model.Department</dd>
                    
                    <dt class="col-sm-5 text-muted small text-uppercase">Semester</dt>
                    <dd class="col-sm-7">Semester @Model.Semester</dd>
                    
                    <dt class="col-sm-5 text-muted small text-uppercase">Email</dt>
                    <dd class="col-sm-7 text-truncate" title="@Model.User.Email">@Model.User.Email</dd>
                </dl>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0 fw-bold"><i class="bi bi-graph-up-arrow me-2"></i>Engagement Summary</h5>
            </div>
            <div class="card-body text-center">
                <div class="row g-3">
                    <div class="col-6 border-end">
                        <h2 class="mb-0 fw-bold text-primary">@ViewBag.TotalDiaries</h2>
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.65rem;">Total Diaries</small>
                    </div>
                    <div class="col-6">
                        <h2 class="mb-0 fw-bold text-warning">@ViewBag.PendingDiaries</h2>
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.65rem;">Pending Approval</small>
                    </div>
                    <div class="col-12 border-top pt-3">
                        <h2 class="mb-0 fw-bold text-info">@ViewBag.TotalTasks</h2>
                        <small class="text-muted text-uppercase fw-bold" style="font-size: 0.65rem;">Tasks Assigned by You</small>
                    </div>
                </div>
                <div class="mt-4">
                    <a asp-action="Diaries" class="btn btn-outline-primary btn-sm w-100 mb-2">Review Diaries</a>
                    <a asp-action="WeeklyReports" class="btn btn-outline-success btn-sm w-100 mb-2">Review Weekly Reports</a>
                    <a asp-action="AssignTask" asp-route-studentId="@Model.StudentId" class="btn btn-outline-info btn-sm w-100">Assign New Task</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Internship Details -->
    <div class="col-md-8">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="bi bi-briefcase-fill text-primary me-2"></i>Internship Profile</h5>
                <a asp-action="StudentDocuments" asp-route-studentId="@Model.StudentId" class="btn btn-sm btn-outline-dark">
                    <i class="bi bi-folder2 me-1"></i> View Submitted Files
                </a>
            </div>
            <div class="card-body">
                @if (internship != null)
                {
                    <div class="mb-4">
                        <div class="display-6 fw-bold text-dark">@internship.CompanyName</div>
                        <span class="badge bg-primary fs-6 mt-1">@internship.Role</span>
                    </div>

                    <div class="row g-4">
                        <div class="col-sm-6">
                            <label class="text-muted small fw-bold text-uppercase d-block mb-1">Technologies</label>
                            <div class="h5">@internship.TechnologyUsed</div>
                        </div>
                        <div class="col-sm-6">
                            <label class="text-muted small fw-bold text-uppercase d-block mb-1">Internship Period</label>
                            <div class="h5">
                                <i class="bi bi-calendar-event me-2"></i>
                                @internship.StartDate.ToString("MMM yyyy") - @internship.EndDate.ToString("MMM yyyy")
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="text-muted small fw-bold text-uppercase d-block mb-1">Project Description</label>
                            <p class="lead" style="font-size: 1.1rem; line-height: 1.6;">
                                @(string.IsNullOrEmpty(internship.Description) ? "The student has not provided a description yet." : internship.Description)
                            </p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-info-circle display-1 text-light mb-3"></i>
                        <h3>Internship Profile Incomplete</h3>
                        <p class="text-muted">The student hasn't added their internship details yet.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
