@model IEnumerable<InternshipManagementSystem.Models.InternshipTask>

@{
    ViewData["Title"] = "Assigned Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Tasks Assigned by Me</h2>
    <a asp-action="AssignTask" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Assign New Task</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Student</th>
                        <th>Deadline</th>
                        <th>Status</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model ?? Enumerable.Empty<InternshipManagementSystem.Models.InternshipTask>())
                    {
                        <tr>
                            <td>@task.Title</td>
                            <td>@task.Student?.User?.Name <span class="text-muted small">(@task.Student?.EnrollmentNumber)</span></td>
                            <td>@task.Deadline.ToShortDateString()</td>
                            <td>
                                @if (task.Status == "Assigned") { <span class="badge bg-secondary">Assigned</span> }
                                else if (task.Status == "InProgress") { <span class="badge bg-primary">In Progress</span> }
                                else if (task.Status == "Completed") { <span class="badge bg-success">Completed</span> }
                                else { <span class="badge bg-light text-dark">@task.Status</span> }
                            </td>
                            <td><small class="text-muted">@(task.Description?.Length > 30 ? task.Description.Substring(0, 30) + "..." : task.Description ?? "—")</small></td>
                        </tr>
                    }
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">No tasks assigned yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
