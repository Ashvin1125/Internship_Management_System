@model IEnumerable<InternshipManagementSystem.Models.Document>

@{
    ViewData["Title"] = "Student Documents";
}

<div class="mb-4">
    <h2>Documents for @ViewBag.StudentName</h2>
    <p class="text-muted">Review files uploaded by the student for this internship.</p>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">File Name</th>
                        <th>Upload Date</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model ?? Enumerable.Empty<InternshipManagementSystem.Models.Document>())
                    {
                        <tr>
                            <td class="ps-4">
                                <i class="bi bi-file-earmark-medical text-primary me-2"></i>
                                <span class="fw-medium">@item.FileName</span>
                            </td>
                            <td>@item.UploadDate.ToString("dd MMM yyyy, hh:mm tt")</td>
                            <td class="text-end pe-4">
                                <a asp-action="DownloadDocument" asp-route-id="@item.DocumentId" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-download me-1"></i> Download
                                </a>
                            </td>
                        </tr>
                    }
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5">
                                <i class="bi bi-folder2 display-4 text-muted d-block mb-2"></i>
                                <p class="text-muted">No documents uploaded by this student.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Students" class="btn btn-secondary">Back to My Students</a>
</div>
