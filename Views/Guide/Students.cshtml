@model IEnumerable<InternshipManagementSystem.Models.GuideAssignment>
@{
    ViewData["Title"] = "Assigned Students";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">My Assigned Students</h2>
</div>

<div class="ims-card p-0 overflow-hidden">
    <div class="ims-table-container">
        <div class="table-responsive-ims">
            <table class="ims-table">
                <thead>
                    <tr>
                        <th>Enrollment</th>
                        <th>Student Name & Email</th>
                        <th>Semester</th>
                        <th class="text-end px-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-primary">@item.Student?.EnrollmentNumber</td>
                                <td>
                                    <div class="fw-bold">@item.Student?.User?.Name</div>
                                    <small class="text-muted">@item.Student?.User?.Email</small>
                                </td>
                                <td><span class="ims-status ims-status-warning">Sem @item.Student?.Semester</span></td>
                                <td class="text-end px-4">
                                    <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                        <a asp-action="StudentDetails" asp-route-id="@item.StudentId" class="btn btn-sm btn-outline-primary border-0 py-2 px-3" title="View Profile">
                                            <i class="bi bi-eye me-1"></i> Profile
                                        </a>
                                        <a asp-action="StudentDocuments" asp-route-studentId="@item.StudentId" class="btn btn-sm btn-outline-dark border-0 py-2 px-3" title="View Documents">
                                            <i class="bi bi-folder2 me-1"></i> Docs
                                        </a>
                                        <a asp-action="AssignTask" asp-route-studentId="@item.StudentId" class="btn btn-sm btn-outline-info border-0 py-2 px-3" title="Assign Task">
                                            <i class="bi bi-plus-circle me-1"></i> Task
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4">
                                <div class="ims-empty-state">
                                    <i class="bi bi-people"></i>
                                    <h5>No Students Assigned</h5>
                                    <p>You haven't been assigned any students yet. Contact the Admin for assignments.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
