@model InternshipManagementSystem.Models.Guide

@{
    ViewData["Title"] = "Guide Details";
    var assignments = ViewBag.AssignedStudents as IEnumerable<InternshipManagementSystem.Models.GuideAssignment>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Guide Profile: @Model.User.Name</h2>
    <a asp-action="Guides" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i> Back to List</a>
</div>

<div class="row">
    <!-- Left Column: Guide Info -->
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-person-badge-fill me-2"></i>Guide Details</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Email</dt>
                    <dd class="col-sm-7">@Model.User.Email</dd>
                    
                    <dt class="col-sm-5">Designation</dt>
                    <dd class="col-sm-7">@Model.Designation</dd>
                    
                    <dt class="col-sm-5">Department</dt>
                    <dd class="col-sm-7">@Model.Department</dd>
                    
                    <dt class="col-sm-5">Joined</dt>
                    <dd class="col-sm-7">@Model.User.CreatedDate.ToShortDateString()</dd>
                </dl>
                <hr>
                <div class="text-center">
                    <h1 class="display-4 fw-bold text-primary mb-0">@(assignments?.Count() ?? 0)</h1>
                    <p class="text-muted text-uppercase small ls-1">Students Supervised</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Assigned Students -->
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-people-fill me-2"></i>Assigned Students</h5>
                <a asp-action="AssignGuide" class="btn btn-sm btn-outline-light"><i class="bi bi-plus-circle me-1"></i> Assign More</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Enroll No</th>
                                <th>Name</th>
                                <th>Department</th>
                                <th class="text-end pe-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (assignments != null && assignments.Any())
                            {
                                foreach (var item in assignments)
                                {
                                    <tr>
                                        <td class="ps-3">@item.Student.EnrollmentNumber</td>
                                        <td>@item.Student.User.Name</td>
                                        <td>@item.Student.Department</td>
                                        <td class="text-end pe-3">
                                            <a asp-action="StudentDetails" asp-route-id="@item.StudentId" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye"></i> View Profile
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5 text-muted">No students assigned to this guide yet.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
