@model IEnumerable<InternshipManagementSystem.Models.Student>

@{
    ViewData["Title"] = "Manage Students";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Students List</h2>
    <a asp-action="CreateStudent" class="btn btn-primary"><i class="bi bi-person-plus me-1"></i> Register Student</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Enrollment No</th>
                    <th>Name</th>
                    <th>Department</th>
                    <th>Sem</th>
                    <th>Registered On</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model ?? Enumerable.Empty<InternshipManagementSystem.Models.Student>())
                {
                    <tr>
                        <td>@item.EnrollmentNumber</td>
                        <td>@item.User?.Name</td>
                        <td>@item.Department</td>
                        <td>@item.Semester</td>
                        <td>@item.User?.CreatedDate.ToShortDateString()</td>
                    </tr>
                }
                @if (Model == null || !Model.Any())
                {
                    <tr><td colspan="5" class="text-center py-4">No students found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
