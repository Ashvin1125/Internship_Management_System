@model IEnumerable<InternshipManagementSystem.Models.Student>

@{
    ViewData["Title"] = "Manage Students";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Students List</h2>
    <a asp-action="CreateStudent" class="ims-btn ims-btn-primary"><i class="bi bi-person-plus me-1"></i> Register Student</a>
</div>

<div class="ims-card p-0 overflow-hidden">
    <div class="ims-table-container">
        <div class="table-responsive-ims">
            <table class="ims-table">
                <thead>
                    <tr>
                        <th>Enrollment</th>
                        <th>Student Name & Email</th>
                        <th>Department</th>
                        <th>Semester</th>
                        <th>Registered</th>
                        <th class="text-end px-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-primary">@item.EnrollmentNumber</td>
                                <td>
                                    <div class="fw-bold">@item.User?.Name</div>
                                    <small class="text-muted">@item.User?.Email</small>
                                </td>
                                <td><span class="ims-status ims-status-success">@item.Department</span></td>
                                <td><span class="ims-status ims-status-warning">Sem @item.Semester</span></td>
                                <td>@item.User?.CreatedDate.ToString("dd MMM yyyy")</td>
                                <td class="text-end px-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="StudentDetails" asp-route-id="@item.StudentId" class="ims-btn ims-btn-primary py-1 px-2 small" title="View Profile">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <form asp-action="DeleteStudent" asp-route-id="@item.StudentId" method="post" onsubmit="return confirm('Are you sure you want to delete this student and all their records?');" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="ims-btn bg-danger text-white py-1 px-2 small" title="Delete Student">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6">
                                <div class="ims-empty-state">
                                    <i class="bi bi-people text-primary"></i>
                                    <h5>No Students Registered</h5>
                                    <p class="mb-0">Click 'Register Student' to add a new intern to the system.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
