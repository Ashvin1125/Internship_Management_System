@model InternshipManagementSystem.ViewModels.CreateGuideViewModel

@{
    ViewData["Title"] = "Add New Guide";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Register Guide</h2>
</div>

<div class="card shadow-sm max-w-md">
    <div class="card-body">
        <form asp-action="CreateGuide" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Name" class="form-label">Full Name</label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" type="email" class="form-control" required />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" type="password" class="form-control" required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            
            <div class="row">
                <div class="col-md-6 mb-4">
                    <label asp-for="Department" class="form-label">Department</label>
                    <select asp-for="Department" class="form-select" required>
                        <option value="">Select Department...</option>
                        <option value="Computer Science">Computer Science</option>
                        <option value="Information Technology">Information Technology</option>
                    </select>
                    <span asp-validation-for="Department" class="text-danger"></span>
                </div>
                
                <div class="col-md-6 mb-4">
                    <label asp-for="Designation" class="form-label">Designation</label>
                    <select asp-for="Designation" class="form-select" required>
                        <option value="">Select Designation...</option>
                        <option value="Professor">Professor</option>
                        <option value="Associate Professor">Associate Professor</option>
                        <option value="Assistant Professor">Assistant Professor</option>
                        <option value="Lecturer">Lecturer</option>
                    </select>
                    <span asp-validation-for="Designation" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Guides" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">Register Guide</button>
            </div>
        </form>
    </div>
</div>
