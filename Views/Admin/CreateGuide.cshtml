@model InternshipManagementSystem.ViewModels.CreateGuideViewModel

@{
    ViewData["Title"] = "Add New Guide";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Register Guide</h2>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card form-card">
            <div class="card-header bg-white py-3 border-bottom-0">
                <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-person-plus-fill me-2"></i>Faculty Registration</h5>
                <p class="text-muted small mb-0">Register a new guide/mentor for internship supervision.</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="CreateGuide" method="post" data-ajax="true">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-4"></div>
                    
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label small fw-bold text-muted text-uppercase mb-1">Full Name</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-person text-muted"></i></span>
                                <input asp-for="Name" class="form-control border-0 bg-light py-2" placeholder="Dr. Alice Smith" required />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label small fw-bold text-muted text-uppercase mb-1">Official Email</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-envelope text-muted"></i></span>
                                <input asp-for="Email" type="email" class="form-control border-0 bg-light py-2" placeholder="alice@university.com" required />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Password" class="form-label small fw-bold text-muted text-uppercase mb-1">Default Password</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-shield-lock text-muted"></i></span>
                                <input asp-for="Password" type="password" class="form-control border-0 bg-light py-2" placeholder="••••••••" required />
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6">
                            <label asp-for="Department" class="form-label small fw-bold text-muted text-uppercase mb-1">Department</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-building text-muted"></i></span>
                                <select asp-for="Department" class="form-select border-0 bg-light py-2" required>
                                    <option value="">Select Dept...</option>
                                    <option value="Computer Science">Computer Science</option>
                                    <option value="Information Technology">Information Technology</option>
                                </select>
                            </div>
                            <span asp-validation-for="Department" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6">
                            <label asp-for="Designation" class="form-label small fw-bold text-muted text-uppercase mb-1">Academic Rank</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-award text-muted"></i></span>
                                <select asp-for="Designation" class="form-select border-0 bg-light py-2" required>
                                    <option value="">Select Rank...</option>
                                    <option value="Professor">Professor</option>
                                    <option value="Associate Professor">Associate Professor</option>
                                    <option value="Assistant Professor">Assistant Professor</option>
                                    <option value="Lecturer">Lecturer</option>
                                </select>
                            </div>
                            <span asp-validation-for="Designation" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-5 d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 py-2 fw-bold shadow-sm">
                            <i class="bi bi-check-circle-fill me-2"></i>Register Guide
                        </button>
                        <a asp-action="Guides" class="btn btn-light px-4 py-2 fw-bold text-muted border">
                            <i class="bi bi-arrow-left me-2"></i>Back to List
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card border-0 bg-light p-4 rounded-4 mt-lg-0 mt-4">
            <h6 class="fw-bold"><i class="bi bi-info-circle-fill text-primary me-2"></i>Guide Access</h6>
            <p class="small text-muted mb-0">Guides can review daily diaries, assign industry tasks, and track the overall internship progress of assigned students.</p>
            <hr class="my-3 opacity-10">
            <ul class="small p-0 m-0 text-muted list-unstyled">
                <li class="mb-2"><i class="bi bi-dot text-primary fs-4 align-middle"></i> Use institutional email IDs only.</li>
                <li><i class="bi bi-dot text-primary fs-4 align-middle"></i> Password can be changed via Profile.</li>
            </ul>
        </div>
    </div>
</div>
