@model IEnumerable<InternshipManagementSystem.Models.Guide>

@{
    ViewData["Title"] = "Manage Guides";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Guides List</h2>
    <a asp-action="CreateGuide" class="ims-btn ims-btn-primary"><i class="bi bi-person-plus me-1"></i> Register Guide</a>
</div>

<div class="ims-card p-0 overflow-hidden">
    <div class="ims-table-container">
        <div class="table-responsive-ims">
            <table class="ims-table">
                <thead>
                    <tr>
                        <th>Guide Name & Email</th>
                        <th>Designation</th>
                        <th>Department</th>
                        <th class="text-end px-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold text-primary">@item.User?.Name</div>
                                    <small class="text-muted">@item.User?.Email</small>
                                </td>
                                <td><span class="ims-status ims-status-info">@item.Designation</span></td>
                                <td><span class="ims-status ims-status-success">@item.Department</span></td>
                                <td class="text-end px-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="GuideDetails" asp-route-id="@item.GuideId" class="ims-btn ims-btn-primary py-1 px-2 small" title="View Profile">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <form asp-action="DeleteGuide" asp-route-id="@item.GuideId" method="post" onsubmit="return confirm('Are you sure you want to delete this guide? This will not delete their historical assignments.');" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="ims-btn bg-danger text-white py-1 px-2 small" title="Delete Guide">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4">
                                <div class="ims-empty-state">
                                    <i class="bi bi-person-badge text-primary"></i>
                                    <h5>No Guides Registered</h5>
                                    <p class="mb-0">Click 'Register Guide' to add faculty or mentors to the system.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
