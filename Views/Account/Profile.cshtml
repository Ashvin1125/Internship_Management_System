@model InternshipManagementSystem.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "User Profile";
}

<div class="row">
    <div class="col-lg-4">
        <!-- Profile Card -->
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
            <div class="bg-primary py-5 text-center">
                <div class="avatar-circle mx-auto mb-3 shadow-lg bg-white text-primary" style="width: 100px; height: 100px; font-size: 40px; line-height: 100px; border-radius: 50%;">
                    @Model.Name.Substring(0, 1).ToUpper()
                </div>
                <h4 class="text-white mb-1">@Model.Name</h4>
                <p class="text-white-50 small mb-0">@Model.Role</p>
            </div>
            <div class="card-body p-4 pt-0 mt-n3">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-envelope text-primary me-3 fs-5"></i>
                            <div>
                                <small class="text-muted d-block">Email Address</small>
                                <span class="fw-bold">@Model.Email</span>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Department))
                        {
                            <div class="d-flex align-items-center mb-3">
                                <i class="bi bi-building text-primary me-3 fs-5"></i>
                                <div>
                                    <small class="text-muted d-block">Department</small>
                                    <span class="fw-bold">@Model.Department</span>
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.EnrollmentOrDesignation))
                        {
                            <div class="d-flex align-items-center">
                                <i class="bi bi-info-circle text-primary me-3 fs-5"></i>
                                <div>
                                    <small class="text-muted d-block">@(Model.Role == "Student" ? "Enrollment No." : "Designation")</small>
                                    <span class="fw-bold">@Model.EnrollmentOrDesignation</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card form-card">
            <div class="card-header bg-white py-3 border-bottom-0">
                <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-person-gear me-2"></i>Account Settings</h5>
                <p class="text-muted small mb-0">Update your personal information and security credentials.</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Profile" method="post" data-ajax="true">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-4"></div>

                    <div class="row g-4">
                        <div class="col-12">
                            <label asp-for="Name" class="form-label small fw-bold text-muted text-uppercase mb-1">Full Name</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-person text-muted"></i></span>
                                <input asp-for="Name" class="form-control border-0 bg-light py-2" placeholder="Enter your full name" required />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Email" class="form-label small fw-bold text-muted text-uppercase mb-1">Email (Read-only)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-envelope-at text-muted"></i></span>
                                <input asp-for="Email" class="form-control border-0 bg-light py-2 opacity-75" readonly />
                            </div>
                            <div class="form-text small italic mt-1">Contact Admin to change your registered email.</div>
                        </div>

                        <div class="col-12 mt-5">
                            <hr class="opacity-10">
                            <h6 class="fw-bold mb-3"><i class="bi bi-shield-lock me-2"></i>Change Password</h6>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="NewPassword" class="form-label small fw-bold text-muted text-uppercase mb-1">New Password</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-key text-muted"></i></span>
                                <input asp-for="NewPassword" type="password" class="form-control border-0 bg-light py-2" placeholder="Leave blank to keep current" />
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label small fw-bold text-muted text-uppercase mb-1">Confirm New Password</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-key-fill text-muted"></i></span>
                                <input asp-for="ConfirmPassword" type="password" class="form-control border-0 bg-light py-2" placeholder="Re-type new password" />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-5 d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 py-2 fw-bold shadow-sm">
                            <i class="bi bi-check2-circle me-2"></i>Update Profile
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
