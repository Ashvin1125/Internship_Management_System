@model InternshipManagementSystem.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
    var sid = ViewContext.RouteData.Values["sid"]?.ToString();
}

<div class="ims-auth-screen">
    <div class="col-md-6 col-lg-5 col-xl-4">
        <div class="ims-card p-0 overflow-hidden border-0 shadow-lg">
            <div class="bg-primary py-5 text-center text-white position-relative overflow-hidden">
                <!-- Decorative Layer for Contrast -->
                <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-25"></div>
                
                <div class="position-relative z-1">
                    <div class="bg-white text-primary d-inline-flex align-items-center justify-content-center rounded-circle shadow-sm mb-3" style="width: 70px; height: 70px;">
                        <i class="bi bi-mortarboard-fill fs-1"></i>
                    </div>
                    <h2 class="fw-bold mb-0" style="letter-spacing: 2px;">IMS PORTAL</h2>
                    <p class="text-white-50 small text-uppercase mt-1 mb-0">Secure Institution Access</p>
                </div>
            </div>
            
            <div class="p-4 p-lg-5">
                <div class="text-center mb-5">
                    <h3 class="fw-bold">Welcome Back</h3>
                    <p class="text-muted small">Please authenticate to continue</p>
                </div>

                <form asp-action="Login" asp-route-sid="@sid" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-4 border-0 shadow-sm" style="background: rgba(220, 53, 69, 0.1); color: #dc3545;"></div>
                    
                    <div class="mb-4">
                        <label asp-for="Email" class="form-label small fw-bold text-muted text-uppercase mb-2">Email Address</label>
                        <div class="ims-input-group">
                            <i class="bi bi-envelope-fill"></i>
                            <input asp-for="Email" class="form-control border-0 bg-light py-3 px-3" placeholder="name@university.edu" autofocus />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    
                    <div class="mb-5">
                        <label asp-for="Password" class="form-label small fw-bold text-muted text-uppercase mb-2">Password</label>
                        <div class="ims-input-group">
                            <i class="bi bi-key-fill"></i>
                            <input asp-for="Password" type="password" class="form-control border-0 bg-light py-3 px-3" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    
                    <div class="d-grid shadow-primary">
                        <button type="submit" class="ims-btn ims-btn-primary justify-content-center py-3">
                            <i class="bi bi-shield-lock-fill me-2"></i> Sign In to Portal
                        </button>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="mt-5 text-center">
            <p class="text-muted small">© @DateTime.Now.Year Internship Management System • Built for Excellence</p>
        </div>
    </div>
</div>

<style>
    .tracking-widest { letter-spacing: 2px; }
    .tracking-wider { letter-spacing: 1px; }
    .transition-transform { transition: transform 0.2s; }
    .transition-transform:active { transform: scale(0.98); }
</style>
