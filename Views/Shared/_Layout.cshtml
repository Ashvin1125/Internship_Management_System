<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Internship Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InternshipManagementSystem.styles.css" asp-append-version="true" />
    <style>
        body {
            display: flex;
            min-height: 100vh;
            margin: 0;
        }
        .sidebar {
            width: 250px;
            background-color: #212529;
            color: #fff;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            transition: all 0.3s;
        }
        .sidebar a {
            color: #adb5bd;
            text-decoration: none;
            padding: 12px 20px;
            display: block;
            font-size: 1.05rem;
            border-left: 3px solid transparent;
        }
        .sidebar a:hover, .sidebar a.active {
            color: #fff;
            background-color: #343a40;
            border-left: 3px solid #0d6efd;
        }
        .main-content {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
            background-color: #f8f9fa;
        }
        .navbar {
            box-shadow: 0 2px 4px rgba(0,0,0,.04);
        }
        .card {
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            border: none;
            border-radius: 0.5rem;
        }
    </style>
</head>
<body>
    @if (User.Identity.IsAuthenticated)
    {
        <div class="sidebar">
            <div class="p-3 border-bottom border-dark text-center">
                <i class="bi bi-mortarboard-fill fs-3 text-primary"></i>
                <h5 class="mt-2 text-white">IMS Portal</h5>
            </div>
            <div class="flex-grow-1 pt-3">
                @if (User.HasClaim(c => c.Type == System.Security.Claims.ClaimTypes.Role && c.Value == "Admin"))
                {
                    <a asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
                    <a asp-controller="Admin" asp-action="Students"><i class="bi bi-people me-2"></i> Manage Students</a>
                    <a asp-controller="Admin" asp-action="Guides"><i class="bi bi-person-badge me-2"></i> Manage Guides</a>
                    <a asp-controller="Admin" asp-action="AssignGuide"><i class="bi bi-link me-2"></i> Assign Guide</a>
                }
                else if (User.HasClaim(c => c.Type == System.Security.Claims.ClaimTypes.Role && c.Value == "Guide"))
                {
                    <a asp-controller="Guide" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
                    <a asp-controller="Guide" asp-action="Students"><i class="bi bi-people me-2"></i> My Students</a>
                    <a asp-controller="Guide" asp-action="Diaries"><i class="bi bi-journal-text me-2"></i> Review Diaries</a>
                    <a asp-controller="Guide" asp-action="Tasks"><i class="bi bi-list-task me-2"></i> View Tasks</a>
                    <a asp-controller="Guide" asp-action="AssignTask"><i class="bi bi-plus-circle me-2"></i> Assign Task</a>
                }
                else if (User.HasClaim(c => c.Type == System.Security.Claims.ClaimTypes.Role && c.Value == "Student"))
                {
                    <a asp-controller="Student" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
                    <a asp-controller="Student" asp-action="Internship"><i class="bi bi-building me-2"></i> My Internship</a>
                    <a asp-controller="Student" asp-action="Diary"><i class="bi bi-journal-plus me-2"></i> Daily Diary</a>
                    <a asp-controller="Student" asp-action="WeeklyReports"><i class="bi bi-file-earmark-text me-2"></i> Weekly Reports</a>
                    <a asp-controller="Student" asp-action="Tasks"><i class="bi bi-list-task me-2"></i> Assigned Tasks</a>
                }
            </div>
            <div class="p-3 border-top border-dark">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-primary rounded-circle text-center text-white me-2" style="width: 35px; height: 35px; line-height: 35px;">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <div>
                        <small class="d-block text-white" style="line-height:1">@User.Identity.Name</small>
                        <small class="text-muted">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</small>
                    </div>
                </div>
                <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger w-100 btn-sm"><i class="bi bi-box-arrow-right me-1"></i> Sign out</a>
            </div>
        </div>
    }

    <div class="main-content">
        @if (User.Identity.IsAuthenticated)
        {
            <header>
                <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom mb-4 py-3">
                    <div class="container-fluid px-4">
                        <h4 class="mb-0 text-dark">@ViewData["Title"]</h4>
                        <div class="d-flex">
                            <span class="text-muted">@DateTime.Now.ToString("dd MMMM yyyy")</span>
                        </div>
                    </div>
                </nav>
            </header>
        }
        
        <div class="container-fluid px-4">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
