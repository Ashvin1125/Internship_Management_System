<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Internship Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InternshipManagementSystem.styles.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body {
            display: flex;
            height: 100vh;
            margin: 0;
            overflow: hidden;
        }
        .sidebar {
            width: 250px;
            background-color: #212529;
            color: #fff;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            transition: all 0.3s;
            position: sticky;
            top: 0;
            height: 100vh;
            overflow-y: auto;
        }
        .sidebar a {
            color: #adb5bd;
            text-decoration: none;
            padding: 12px 20px;
            display: block;
            font-size: 1.05rem;
            border-left: 3px solid transparent;
        }
        .sidebar a:hover, .sidebar a.active {
            color: #fff;
            background-color: #343a40;
            border-left: 3px solid #0d6efd;
        }
        .main-content {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
            overflow-y: auto;
            background-color: #f8f9fa;
            height: 100vh;
        }
        .navbar {
            box-shadow: 0 2px 4px rgba(0,0,0,.04);
            position: sticky;
            top: 0;
            background-color: #fff;
            z-index: 1000;
        }
        .card {
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            border: none;
            border-radius: 0.5rem;
        }
    </style>
</head>
<body>
    @{
        var sid = ViewContext.RouteData.Values["sid"]?.ToString();
    }
    @if (User.Identity.IsAuthenticated)
    {
        <div class="sidebar">
            <div class="p-3 border-bottom border-dark text-center">
                <i class="bi bi-mortarboard-fill fs-3 text-primary"></i>
                <h5 class="mt-2 text-white">IMS Portal</h5>
            </div>
            <div class="flex-grow-1 pt-3">
                @functions {
                    string IsActive(string controller, string action) {
                        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                        return string.Equals(controller, currentController, StringComparison.OrdinalIgnoreCase) && 
                               string.Equals(action, currentAction, StringComparison.OrdinalIgnoreCase) ? "active" : "";
                    }
                }
                @if (User.HasClaim(c => c.Type == System.Security.Claims.ClaimTypes.Role && c.Value == "Admin"))
                {
                    <a asp-controller="Admin" asp-action="Index" asp-route-sid="@sid" class="@IsActive("Admin", "Index")"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
                    <a asp-controller="Admin" asp-action="Students" asp-route-sid="@sid" class="@IsActive("Admin", "Students")"><i class="bi bi-people me-2"></i> Manage Students</a>
                    <a asp-controller="Admin" asp-action="Guides" asp-route-sid="@sid" class="@IsActive("Admin", "Guides")"><i class="bi bi-person-badge me-2"></i> Manage Guides</a>
                    <a asp-controller="Admin" asp-action="AssignGuide" asp-route-sid="@sid" class="@IsActive("Admin", "AssignGuide")"><i class="bi bi-link me-2"></i> Assign Guide</a>
                    <div class="mt-3 border-top border-dark opacity-25"></div>
                    <a asp-controller="Account" asp-action="Profile" asp-route-sid="@sid" class="@IsActive("Account", "Profile")"><i class="bi bi-person-circle me-2"></i> My Profile</a>
                }
                else if (User.HasClaim(c => c.Type == System.Security.Claims.ClaimTypes.Role && c.Value == "Guide"))
                {
                    <a asp-controller="Guide" asp-action="Index" asp-route-sid="@sid" class="@IsActive("Guide", "Index")"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
                    <a asp-controller="Guide" asp-action="Students" asp-route-sid="@sid" class="@IsActive("Guide", "Students")"><i class="bi bi-people me-2"></i> My Students</a>
                    <a asp-controller="Guide" asp-action="Diaries" asp-route-sid="@sid" class="@IsActive("Guide", "Diaries")"><i class="bi bi-journal-text me-2"></i> Review Diaries</a>
                    <a asp-controller="Guide" asp-action="Tasks" asp-route-sid="@sid" class="@IsActive("Guide", "Tasks")"><i class="bi bi-list-task me-2"></i> View Tasks</a>
                    <a asp-controller="Guide" asp-action="AssignTask" asp-route-sid="@sid" class="@IsActive("Guide", "AssignTask")"><i class="bi bi-plus-circle me-2"></i> Assign Task</a>
                    <div class="mt-3 border-top border-dark opacity-25"></div>
                    <a asp-controller="Account" asp-action="Profile" asp-route-sid="@sid" class="@IsActive("Account", "Profile")"><i class="bi bi-person-circle me-2"></i> My Profile</a>
                }
                else if (User.HasClaim(c => c.Type == System.Security.Claims.ClaimTypes.Role && c.Value == "Student"))
                {
                    <a asp-controller="Student" asp-action="Index" asp-route-sid="@sid" class="@IsActive("Student", "Index")"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
                    <a asp-controller="Student" asp-action="Internship" asp-route-sid="@sid" class="@IsActive("Student", "Internship")"><i class="bi bi-building me-2"></i> My Internship</a>
                    <a asp-controller="Student" asp-action="Diary" asp-route-sid="@sid" class="@IsActive("Student", "Diary")"><i class="bi bi-journal-plus me-2"></i> Daily Diary</a>
                    <a asp-controller="Student" asp-action="WeeklyReports" asp-route-sid="@sid" class="@IsActive("Student", "WeeklyReports")"><i class="bi bi-file-earmark-text me-2"></i> Weekly Reports</a>
                    <a asp-controller="Student" asp-action="Tasks" asp-route-sid="@sid" class="@IsActive("Student", "Tasks")"><i class="bi bi-list-task me-2"></i> Assigned Tasks</a>
                    <a asp-controller="Student" asp-action="Documents" asp-route-sid="@sid" class="@IsActive("Student", "Documents")"><i class="bi bi-folder2 me-2"></i> My Documents</a>
                    <div class="mt-3 border-top border-dark opacity-25"></div>
                    <a asp-controller="Account" asp-action="Profile" asp-route-sid="@sid" class="@IsActive("Account", "Profile")"><i class="bi bi-person-circle me-2"></i> My Profile</a>
                }
            </div>
        </div>
    }

    <div class="main-content">
        @if (User.Identity.IsAuthenticated)
        {
            <header>
                <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom mb-4 py-2">
                    <div class="container-fluid px-4">
                        <h4 class="mb-0 text-dark">@ViewData["Title"]</h4>
                        
                        <div class="d-flex align-items-center">
                            <a asp-controller="Account" asp-action="Profile" asp-route-sid="@sid" class="d-flex align-items-center text-decoration-none me-3 pe-3 border-end">
                                <div class="text-end d-none d-md-block me-3">
                                    <span class="d-block text-dark fw-bold" style="font-size: 0.9rem;">@User.Identity.Name</span>
                                    <small class="text-muted" style="font-size: 0.75rem;">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value | @DateTime.Now.ToString("dd MMM")</small>
                                </div>
                                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 38px; height: 38px;">
                                    <i class="bi bi-person-fill text-primary"></i>
                                </div>
                            </a>
                            <a asp-controller="Account" asp-action="Logout" asp-route-sid="@sid" class="btn btn-sm btn-outline-danger px-3 rounded-pill fw-bold">
                                <i class="bi bi-box-arrow-right me-1"></i> Logout
                            </a>
                        </div>
                    </div>
                </nav>
            </header>
        }
        
        <div class="container-fluid px-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
