@model InternshipManagementSystem.ViewModels.InternshipDetailsViewModel

@{
    ViewData["Title"] = "Add Internship Details";
}

<div class="row">
    <div class="col-lg-8">
        <div class="card form-card">
            <div class="card-header bg-white py-3 border-bottom-0">
                <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-briefcase-fill me-2"></i>Internship Profile</h5>
                <p class="text-muted small mb-0">Provide details about your current or upcoming internship placement.</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="AddInternship" method="post" data-ajax="true">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-4"></div>
                    
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label asp-for="CompanyName" class="form-label small fw-bold text-muted text-uppercase mb-1">Company / Organization</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-building text-muted"></i></span>
                                <input asp-for="CompanyName" class="form-control border-0 bg-light py-2" placeholder="e.g. Google India" required />
                            </div>
                            <span asp-validation-for="CompanyName" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6">
                            <label asp-for="Role" class="form-label small fw-bold text-muted text-uppercase mb-1">Job Role / Position</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-person-workspace text-muted"></i></span>
                                <input asp-for="Role" class="form-control border-0 bg-light py-2" placeholder="e.g. Software Engineer Intern" required />
                            </div>
                            <span asp-validation-for="Role" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="TechnologyUsed" class="form-label small fw-bold text-muted text-uppercase mb-1">Core Tech Stack</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-cpu text-muted"></i></span>
                                <input asp-for="TechnologyUsed" class="form-control border-0 bg-light py-2" placeholder="e.g. ASP.NET Core, React, SQL Server" />
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label small fw-bold text-muted text-uppercase mb-1">Start Date</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-calendar-check text-muted"></i></span>
                                <input asp-for="StartDate" type="date" class="form-control border-0 bg-light py-2" required />
                            </div>
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label small fw-bold text-muted text-uppercase mb-1">End Date</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-calendar-x text-muted"></i></span>
                                <input asp-for="EndDate" type="date" class="form-control border-0 bg-light py-2" required />
                            </div>
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="form-label small fw-bold text-muted text-uppercase mb-1">Internship Summary</label>
                            <textarea asp-for="Description" class="form-control border-0 bg-light py-2" rows="5" placeholder="Briefly describe your key responsibilities and learnings..."></textarea>
                        </div>
                    </div>

                    <div class="mt-5 d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 py-2 fw-bold shadow-sm">
                            <i class="bi bi-check-circle-fill me-2"></i>Save Internship
                        </button>
                        <a asp-action="Internship" class="btn btn-light px-4 py-2 fw-bold text-muted border">
                            <i class="bi bi-arrow-left me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card border-0 bg-light p-4 rounded-4 mt-lg-0 mt-4">
            <h6 class="fw-bold"><i class="bi bi-info-circle-fill text-primary me-2"></i>Important Note</h6>
            <p class="small text-muted mb-0">This information will be visible to your Guide and used for final assessment. Ensure all details are accurate as per your offer letter.</p>
            <hr class="my-3 opacity-10">
            <ul class="small p-0 m-0 text-muted list-unstyled">
                <li class="mb-2"><i class="bi bi-dot text-primary fs-4 align-middle"></i> Start date should be valid.</li>
                <li><i class="bi bi-dot text-primary fs-4 align-middle"></i> Description can be updated later.</li>
            </ul>
        </div>
    </div>
</div>
