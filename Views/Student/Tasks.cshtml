@model IEnumerable<InternshipManagementSystem.Models.InternshipTask>

@{
    ViewData["Title"] = "My Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Assigned Tasks</h2>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-custom table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th class="px-3">Task Overview</th>
                        <th>Assigned By</th>
                        <th>Deadline</th>
                        <th>Current Status</th>
                        <th class="text-end px-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var task in Model)
                        {
                            <tr>
                                <td class="px-3">
                                    <div class="fw-bold text-dark">@task.Title</div>
                                    <small class="text-muted d-block" style="max-width: 250px;">@(task.Description?.Length > 60 ? task.Description.Substring(0, 60) + "..." : task.Description ?? "No description provided.")</small>
                                </td>
                                <td><span class="badge bg-light text-dark border"><i class="bi bi-person me-1"></i> @task.Guide?.User?.Name</span></td>
                                <td>
                                    @if (task.Deadline < DateTime.Now.Date && task.Status != "Completed")
                                    {
                                        <span class="text-danger fw-bold small"><i class="bi bi-exclamation-triangle-fill me-1"></i> @task.Deadline.ToString("dd MMM yyyy")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">@task.Deadline.ToString("dd MMM yyyy")</span>
                                    }
                                </td>
                                <td>
                                    @if (task.Status == "Assigned") { <span class="status-badge status-info">Assigned</span> }
                                    else if (task.Status == "InProgress") { <span class="status-badge status-pending">In Progress</span> }
                                    else { <span class="status-badge status-approved">Completed</span> }
                                </td>
                                <td class="text-end px-4">
                                    @if (task.Status != "Completed")
                                    {
                                        <form asp-action="UpdateTaskStatus" method="post" class="d-flex gap-2" data-ajax="true">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="taskId" value="@task.TaskId" />
                                            <div class="btn-group shadow-sm">
                                                @if (task.Status == "Assigned")
                                                {
                                                    <button type="submit" name="status" value="InProgress" class="btn btn-sm btn-outline-primary" title="Start Working">
                                                        <i class="bi bi-play-fill me-1"></i>Start
                                                    </button>
                                                }
                                                <button type="submit" name="status" value="Completed" class="btn btn-sm btn-success" title="Mark as Finished">
                                                    <i class="bi bi-check-circle me-1"></i>Done
                                                </button>
                                            </div>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 py-2 px-3">
                                            <i class="bi bi-check-circle-fill me-1"></i> Finished
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    <i class="bi bi-list-check text-muted"></i>
                                    <h5>No Tasks Assigned</h5>
                                    <p class="mb-0">You're all caught up! No tasks have been assigned by your guide yet.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
