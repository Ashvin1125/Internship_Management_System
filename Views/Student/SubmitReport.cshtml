@model InternshipManagementSystem.Models.WeeklyReport

@{
    ViewData["Title"] = "Submit Weekly Report";
}

<div class="row">
    <div class="col-lg-7">
        <div class="card form-card">
            <div class="card-header bg-white py-3 border-bottom-0">
                <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-file-earmark-check me-2"></i>Weekly Progress Report</h5>
                <p class="text-muted small mb-0">Summarize your activities and achievements for the current week.</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="SubmitReport" method="post" data-ajax="true">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-4"></div>
                    
                    <div class="mb-4">
                        <label asp-for="WeekNumber" class="form-label small fw-bold text-muted text-uppercase mb-1">Week Number</label>
                        <div class="input-group w-50">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-hash text-muted"></i></span>
                            <input asp-for="WeekNumber" type="number" min="1" max="52" class="form-control border-0 bg-light py-2" placeholder="e.g. 5" required />
                        </div>
                        <span asp-validation-for="WeekNumber" class="text-danger small"></span>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Summary" class="form-label small fw-bold text-muted text-uppercase mb-1">Weekly Summary & Key Learnings</label>
                        <textarea asp-for="Summary" class="form-control border-0 bg-light py-2" rows="8"
                            placeholder="Provide a high-level overview of your project progress, modules completed, and any technical skills acquired this week..." required></textarea>
                        <span asp-validation-for="Summary" class="text-danger small"></span>
                    </div>

                    <div class="mt-5 d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 py-2 fw-bold shadow-sm">
                            <i class="bi bi-send-check-fill me-2"></i>Submit Report
                        </button>
                        <a asp-action="WeeklyReports" class="btn btn-light px-4 py-2 fw-bold text-muted border">
                            <i class="bi bi-arrow-left me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-lg-5">
        <div class="card border-0 bg-light p-4 rounded-4 mt-lg-0 mt-4">
            <h6 class="fw-bold"><i class="bi bi-journal-check text-primary me-2"></i>Report Guidelines</h6>
            <p class="small text-muted mb-0">Your weekly report should be more comprehensive than daily diaries.</p>
            <hr class="my-3 opacity-10">
            <ul class="small p-0 m-0 text-muted list-unstyled">
                <li class="mb-3">
                    <div class="fw-bold text-dark">Accomplishments</div>
                    <div class="text-muted">Mention major modules or features completed this week.</div>
                </li>
                <li class="mb-3">
                    <div class="fw-bold text-dark">Technical Growth</div>
                    <div class="text-muted">List any new technologies or libraries you learned.</div>
                </li>
                <li>
                    <div class="fw-bold text-dark">Plan for Next Week</div>
                    <div class="text-muted">Briefly state your upcoming goals.</div>
                </li>
            </ul>
        </div>
    </div>
</div>
