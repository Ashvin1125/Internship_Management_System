@model IEnumerable<InternshipManagementSystem.Models.DailyDiary>

@{
    ViewData["Title"] = "Daily Diaries";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">My Daily Diaries</h2>
    <a asp-action="CreateDiary" class="ims-btn ims-btn-primary"><i class="bi bi-plus-circle me-1"></i> Add New Entry</a>
</div>

<div class="ims-card p-0 overflow-hidden">
    <div class="ims-table-container">
        <div class="table-responsive-ims">
            <table class="ims-table">
                <thead>
                    <tr>
                        <th style="width: 150px;">Work Date</th>
                        <th>Work Description</th>
                        <th style="width: 120px;">Status</th>
                        <th class="px-3">Guide Feedback</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="ims-status ims-status-success bg-opacity-10 text-dark border-0"><i class="bi bi-calendar-event me-1"></i> @item.WorkDate.ToString("dd MMM yyyy")</span></td>
                                <td class="small text-muted">@(item.WorkDescription.Length > 80 ? item.WorkDescription.Substring(0, 80) + "..." : item.WorkDescription)</td>
                                <td>
                                    @if(item.Status == "Pending") { <span class="ims-status ims-status-warning">Pending</span> }
                                    else if(item.Status == "Approved") { <span class="ims-status ims-status-success">Approved</span> }
                                    else { <span class="ims-status ims-status-danger">Rejected</span> }
                                </td>
                                <td class="px-3">
                                    @if (!string.IsNullOrEmpty(item.GuideComment))
                                    {
                                        <div class="p-3 bg-light bg-opacity-50 rounded small text-muted border-start border-3 @(item.Status == "Approved" ? "border-success" : "border-danger")">
                                            @item.GuideComment
                                        </div>
                                    }
                                    else if (item.Status == "Pending")
                                    {
                                        <span class="text-muted small italic">Waiting for review...</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No comment.</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4">
                                <div class="ims-empty-state">
                                    <i class="bi bi-journal-plus text-primary"></i>
                                    <h5>No Diary Entries Yet</h5>
                                    <p class="mb-0">Start recording your daily progress by clicking 'Add New Entry'.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
