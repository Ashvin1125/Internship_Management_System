@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="ims-card h-100 border-start border-primary border-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small fw-bold text-uppercase mb-1">Daily Diaries</p>
                    <h2 class="mb-0 fw-bold px-0">@ViewBag.TotalDiaries</h2>
                </div>
                <div class="bg-primary bg-opacity-10 p-3 rounded-circle">
                    <i class="bi bi-journal-text fs-4 text-primary"></i>
                </div>
            </div>
            <div class="mt-3">
                <a class="small text-primary fw-bold text-decoration-none stretched-link" asp-action="Diary">View Records <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ims-card h-100 border-start border-warning border-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small fw-bold text-uppercase mb-1">Total Tasks</p>
                    <h2 class="mb-0 fw-bold text-warning px-0">@ViewBag.TasksAssigned</h2>
                </div>
                <div class="bg-warning bg-opacity-10 p-3 rounded-circle">
                    <i class="bi bi-list-task fs-4 text-warning"></i>
                </div>
            </div>
            <div class="mt-3">
                <a class="small text-warning fw-bold text-decoration-none stretched-link" asp-action="Tasks">View Tasks <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ims-card h-100 border-start border-danger border-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small fw-bold text-uppercase mb-1">Pending Tasks</p>
                    <h2 class="mb-0 fw-bold text-danger px-0">@ViewBag.PendingTasks</h2>
                </div>
                <div class="bg-danger bg-opacity-10 p-3 rounded-circle">
                    <i class="bi bi-hourglass-split fs-4 text-danger"></i>
                </div>
            </div>
            <div class="mt-3">
                <a class="small text-danger fw-bold text-decoration-none stretched-link" asp-action="Tasks">Pending Fix <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ims-card h-100 border-start @(ViewBag.HasInternship == true ? "border-success" : "border-secondary") border-4 text-center">
            <div class="d-flex justify-content-between align-items-start text-start">
                <div>
                    <p class="text-muted small fw-bold text-uppercase mb-1">Internship</p>
                    <h6 class="mb-0 @(ViewBag.HasInternship == true ? "text-success fw-bold" : "text-muted")">
                        @(ViewBag.HasInternship == true ? "Active" : "Not Defined")
                    </h6>
                </div>
                <div class="@(ViewBag.HasInternship == true ? "bg-success" : "bg-secondary") bg-opacity-10 p-3 rounded-circle">
                    <i class="bi bi-building fs-4 @(ViewBag.HasInternship == true ? "text-success" : "text-secondary")"></i>
                </div>
            </div>
            <div class="mt-3 text-start">
                <a class="small @(ViewBag.HasInternship == true ? "text-success" : "text-secondary") fw-bold text-decoration-none stretched-link" asp-action="Internship">View Details <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="ims-card h-100">
            <div class="border-bottom border-light pb-3 mb-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-lightning-fill text-warning me-2"></i>Quick Actions</h5>
            </div>
            <div class="list-group list-group-flush bg-transparent">
                <a asp-action="CreateDiary" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 border-0 rounded bg-transparent ims-hover-accent">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-primary bg-opacity-10 p-2 rounded-circle"><i class="bi bi-plus-circle text-primary"></i></div>
                        <span class="fw-bold">Add Today's Diary Entry</span>
                    </div>
                    <i class="bi bi-chevron-right small text-muted"></i>
                </a>
                <a asp-action="SubmitReport" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 border-0 rounded bg-transparent ims-hover-accent">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-success bg-opacity-10 p-2 rounded-circle"><i class="bi bi-file-earmark-text text-success"></i></div>
                        <span class="fw-bold">Submit Weekly Progress Report</span>
                    </div>
                    <i class="bi bi-chevron-right small text-muted"></i>
                </a>
                <a asp-action="Internship" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 border-0 rounded bg-transparent ims-hover-accent">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-secondary bg-opacity-10 p-2 rounded-circle"><i class="bi bi-building text-secondary"></i></div>
                        <span class="fw-bold">Manage Internship Details</span>
                    </div>
                    <i class="bi bi-chevron-right small text-muted"></i>
                </a>
            </div>
        </div>
    </div>
</div>
