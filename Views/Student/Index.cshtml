@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card card-stats h-100 border-start border-primary border-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small fw-bold text-uppercase mb-1">Daily Diaries</p>
                        <h2 class="mb-0 fw-bold">@ViewBag.TotalDiaries</h2>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-2 rounded">
                        <i class="bi bi-journal-text fs-4 text-primary"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <a class="small text-primary fw-bold text-decoration-none stretched-link" asp-action="Diary">View Records <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card card-stats h-100 border-start border-warning border-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small fw-bold text-uppercase mb-1">Total Tasks</p>
                        <h2 class="mb-0 fw-bold text-warning">@ViewBag.TasksAssigned</h2>
                    </div>
                    <div class="bg-warning bg-opacity-10 p-2 rounded">
                        <i class="bi bi-list-task fs-4 text-warning"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <a class="small text-warning fw-bold text-decoration-none stretched-link" asp-action="Tasks">View Tasks <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card card-stats h-100 border-start border-danger border-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small fw-bold text-uppercase mb-1">Pending Tasks</p>
                        <h2 class="mb-0 fw-bold text-danger">@ViewBag.PendingTasks</h2>
                    </div>
                    <div class="bg-danger bg-opacity-10 p-2 rounded">
                        <i class="bi bi-hourglass-split fs-4 text-danger"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <a class="small text-danger fw-bold text-decoration-none stretched-link" asp-action="Tasks">Pending Fix <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card card-stats h-100 border-start @(ViewBag.HasInternship == true ? "border-success" : "border-secondary") border-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small fw-bold text-uppercase mb-1">Internship</p>
                        <h6 class="mb-0 @(ViewBag.HasInternship == true ? "text-success fw-bold" : "text-muted")">
                            @(ViewBag.HasInternship == true ? "Active" : "Not Defined")
                        </h6>
                    </div>
                    <div class="@(ViewBag.HasInternship == true ? "bg-success" : "bg-secondary") bg-opacity-10 p-2 rounded">
                        <i class="bi bi-building fs-4 @(ViewBag.HasInternship == true ? "text-success" : "text-secondary")"></i>
                    </div>
                </div>
                <div class="mt-3">
                    <a class="small @(ViewBag.HasInternship == true ? "text-success" : "text-secondary") fw-bold text-decoration-none stretched-link" asp-action="Internship">View Details <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-lightning-fill text-warning me-2"></i>My Actions</h5>
            </div>
            <div class="card-body">
                <div class="list-group list-group-flush">
                    <a asp-action="CreateDiary" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3">
                        <span><i class="bi bi-plus-circle me-2 text-primary"></i> Add Today's Diary Entry</span>
                        <i class="bi bi-chevron-right small text-muted"></i>
                    </a>
                    <a asp-action="SubmitReport" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3">
                        <span><i class="bi bi-file-earmark-text me-2 text-success"></i> Submit Weekly Progress Report</span>
                        <i class="bi bi-chevron-right small text-muted"></i>
                    </a>
                    <a asp-action="Internship" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3">
                        <span><i class="bi bi-building me-2 text-secondary"></i> Manage Internship Details</span>
                        <i class="bi bi-chevron-right small text-muted"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
