@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="card-title">Daily Diaries</h6>
                    <h2 class="mb-0">@ViewBag.TotalDiaries</h2>
                </div>
                <i class="bi bi-journal-text fs-1 text-white-50"></i>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
                <a class="small text-white stretched-link" asp-action="Diary">View All</a>
                <i class="bi bi-arrow-right text-white"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-dark h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="card-title">Total Tasks</h6>
                    <h2 class="mb-0">@ViewBag.TasksAssigned</h2>
                </div>
                <i class="bi bi-list-task fs-1 opacity-50"></i>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
                <a class="small text-dark stretched-link" asp-action="Tasks">View Tasks</a>
                <i class="bi bi-arrow-right"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="card-title">Pending Tasks</h6>
                    <h2 class="mb-0">@ViewBag.PendingTasks</h2>
                </div>
                <i class="bi bi-hourglass-split fs-1 text-white-50"></i>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
                <a class="small text-white stretched-link" asp-action="Tasks">Go to Tasks</a>
                <i class="bi bi-arrow-right text-white"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card @(ViewBag.HasInternship == true ? "bg-success" : "bg-secondary") text-white h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="card-title">Internship</h6>
                    <h4 class="mb-0">@(ViewBag.HasInternship == true ? "Added ✓" : "Not Set")</h4>
                </div>
                <i class="bi bi-building fs-1 text-white-50"></i>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
                <a class="small text-white stretched-link" asp-action="Internship">View Details</a>
                <i class="bi bi-arrow-right text-white"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-lightning-fill text-warning me-2"></i>Quick Actions</div>
            <div class="card-body d-flex flex-column gap-2">
                <a asp-action="CreateDiary" class="btn btn-outline-primary"><i class="bi bi-plus-circle me-2"></i>Add Diary Entry</a>
                <a asp-action="SubmitReport" class="btn btn-outline-success"><i class="bi bi-file-earmark-text me-2"></i>Submit Weekly Report</a>
                <a asp-action="Internship" class="btn btn-outline-secondary"><i class="bi bi-building me-2"></i>View Internship Details</a>
            </div>
        </div>
    </div>
</div>
