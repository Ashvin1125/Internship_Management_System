@model IEnumerable<InternshipManagementSystem.Models.Document>

@{
    ViewData["Title"] = "My Documents";
}

<div class="row align-items-center mb-4">
    <div class="col-md-7">
        <h2 class="fw-bold mb-1">Documents & Submissions</h2>
        <p class="text-muted mb-0 small">Manage your internship project reports, presentations, and technical documentation.</p>
    </div>
</div>

<div class="ims-card border-0 mb-4 overflow-hidden">
    <div class="border-bottom border-light pb-3 mb-3">
        <h5 class="fw-bold text-primary mb-0"><i class="bi bi-cloud-arrow-up-fill me-2"></i>Upload New Submission</h5>
    </div>
    <form asp-action="UploadDocument" method="post" enctype="multipart/form-data" class="row g-3 align-items-end">
        @Html.AntiForgeryToken()
        <div class="col-md-8">
            <label class="form-label small fw-bold text-muted text-uppercase mb-1">Select File (max 50MB)</label>
            <input type="file" name="file" class="form-control border-0 bg-light py-2" required />
        </div>
        <div class="col-md-4">
            <button type="submit" class="ims-btn ims-btn-primary w-100 justify-content-center shadow-sm">
                <i class="bi bi-cloud-arrow-up"></i> Confirm Upload
            </button>
        </div>
    </form>
</div>

<div class="ims-card p-0 overflow-hidden">
    <div class="ims-table-container">
        <div class="table-responsive-ims">
            <table class="ims-table">
                <thead>
                    <tr>
                        <th class="ps-4">File Repository</th>
                        <th>Submission Date</th>
                        <th class="text-end pe-4">Manage</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3">
                                            <i class="bi bi-file-earmark-text text-primary fs-5"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@item.FileName</div>
                                            <small class="text-muted">Type: @System.IO.Path.GetExtension(item.FileName).ToUpper().Replace(".", "")</small>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="text-muted">@item.UploadDate.ToString("dd MMM yyyy, hh:mm tt")</span></td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2 text-end pe-4">
                                        <a asp-action="DownloadDocument" asp-route-id="@item.DocumentId" class="ims-btn ims-btn-primary py-1 px-2 small" title="Download File">
                                            <i class="bi bi-download"></i>
                                        </a>
                                        <form asp-action="DeleteDocument" asp-route-id="@item.DocumentId" method="post" onsubmit="return confirm('Are you sure you want to permanently delete this file?');" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="ims-btn bg-danger text-white py-1 px-2 small" title="Remove Document">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3">
                                <div class="ims-empty-state">
                                    <i class="bi bi-cloud-slash text-primary"></i>
                                    <h5>No Documents Found</h5>
                                    <p class="mb-0">Your submission list is empty. Start by uploading your first document.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
