@model IEnumerable<InternshipManagementSystem.Models.WeeklyReport>

@{
    ViewData["Title"] = "Weekly Reports";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Weekly Reports</h2>
    <a asp-action="SubmitReport" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Submit Report</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-custom table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Report Week</th>
                        <th>Progress Summary</th>
                        <th>Status</th>
                        <th class="px-3">Guide Feedback</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var r in Model)
                        {
                            <tr>
                                <td>
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2 fw-bold">
                                        <i class="bi bi-calendar3 me-2"></i> Week @r.WeekNumber
                                    </span>
                                </td>
                                <td class="small">@(r.Summary.Length > 80 ? r.Summary.Substring(0, 80) + "..." : r.Summary)</td>
                                <td>
                                    @if(r.Status == "Pending") { <span class="status-badge status-pending">Pending</span> }
                                    else if(r.Status == "Approved") { <span class="status-badge status-approved">Approved</span> }
                                    else { <span class="status-badge status-rejected">Rejected</span> }
                                </td>
                                <td class="px-3">
                                    @if (!string.IsNullOrEmpty(r.GuideComment))
                                    {
                                        <div class="p-2 bg-light rounded shadow-none small text-muted border-start border-3 @(r.Status == "Approved" ? "border-success" : "border-danger")">
                                            @r.GuideComment
                                        </div>
                                    }
                                    else if (r.Status == "Pending")
                                    {
                                        <span class="text-muted small italic">Under review...</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No feedback yet.</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4">
                                <div class="empty-state py-5">
                                    <i class="bi bi-file-earmark-bar-graph text-muted display-4 d-block mb-3"></i>
                                    <h5>No Reports Submitted</h5>
                                    <p class="text-muted mb-0">Your weekly report history is empty. Submit your first progress report now.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
