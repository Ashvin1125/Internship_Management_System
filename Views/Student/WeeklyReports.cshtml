@model IEnumerable<InternshipManagementSystem.Models.WeeklyReport>

@{
    ViewData["Title"] = "Weekly Reports";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">My Weekly Reports</h2>
    <a asp-action="SubmitReport" class="ims-btn ims-btn-primary"><i class="bi bi-plus-circle me-1"></i> Submit Report</a>
</div>

<div class="ims-card p-0 overflow-hidden">
    <div class="ims-table-container">
        <div class="table-responsive-ims">
            <table class="ims-table">
                <thead>
                    <tr>
                        <th>Report Week</th>
                        <th>Progress Summary</th>
                        <th>Status</th>
                        <th class="px-3">Guide Feedback</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var r in Model)
                        {
                            <tr>
                                <td>
                                    <span class="ims-status ims-status-info">
                                        <i class="bi bi-calendar3 me-2"></i> Week @r.WeekNumber
                                    </span>
                                </td>
                                <td class="small">@(r.Summary.Length > 80 ? r.Summary.Substring(0, 80) + "..." : r.Summary)</td>
                                <td>
                                    @if(r.Status == "Pending") { <span class="ims-status ims-status-warning">Pending</span> }
                                    else if(r.Status == "Approved") { <span class="ims-status ims-status-success">Approved</span> }
                                    else { <span class="ims-status ims-status-danger">Rejected</span> }
                                </td>
                                <td class="px-3">
                                    @if (!string.IsNullOrEmpty(r.GuideComment))
                                    {
                                        <div class="p-2 bg-light rounded shadow-none small text-muted border-start border-3 @(r.Status == "Approved" ? "border-success" : "border-danger")">
                                            @r.GuideComment
                                        </div>
                                    }
                                    else if (r.Status == "Pending")
                                    {
                                        <span class="text-muted small italic">Under review...</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No feedback yet.</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4">
                                <div class="ims-empty-state">
                                    <i class="bi bi-file-earmark-bar-graph text-primary"></i>
                                    <h5>No Reports Submitted</h5>
                                    <p class="mb-0">Your weekly report history is empty. Submit your first progress report now.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
